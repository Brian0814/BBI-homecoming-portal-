rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // Global safety net - deny all by default
    match /{document=**} {
      allow read, write: if false;
    }

    function isValidId(id) {
      return id is string && id.size() <= 128 && id.matches('^[a-zA-Z0-9_\\-]+$');
    }

    function isValidRegistration(data) {
      return data.ref is string && data.ref.size() <= 64
          && data.date is string
          && data.formData is map;
    }

    match /registrations/{registrationId} {
      allow read: if isValidId(registrationId);
      allow create: if isValidId(registrationId) && isValidRegistration(request.resource.data);
      allow update: if isValidId(registrationId) && isValidRegistration(request.resource.data);
      allow delete: if isValidId(registrationId);
    }
  }
}
